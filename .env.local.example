# Supabase ForFish (znzgugvfhgmiszqgjulk)
NEXT_PUBLIC_SUPABASE_URL=https://znzgugvfhgmiszqgjulk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER ONLY — tạo user + magic-link phía ForFish. Dashboard → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SSO: ForFish verify mật khẩu khách bằng cách signInWithPassword TRỰC TIẾP
# lên Supabase Auth của CRM SDViCo (cùng pattern email {SĐT}@sdvico.local).
# Khi 2 biến này trống → /api/auth/sso trả 503, /login fallback xác thực
# nội bộ ForFish (đăng ký /dang-ky).
SDWORK_SUPABASE_URL=https://exueouggmbjtjvsvpfya.supabase.co
SDWORK_SUPABASE_ANON_KEY=sb_publishable_...           # publishable/anon, KHÔNG service-role

# ── Đợt 1: app khách hàng riêng (đăng nhập SĐT+mật khẩu + webhook ingest) ──
# Webhook SDWork→SDFish nạp KH/thiết bị/vật tư + provision tài khoản (SĐT+mk).
# HMAC chung 2 bên. KHÔNG email/OTP.
SDWORK_WEBHOOK_SECRET=

# Base URL của API route cho bản NATIVE (Capacitor). Web để TRỐNG (fetch tương
# đối cùng origin như cũ). Khi build app iOS/Android, set = URL web đã deploy để
# fetch /api/* trỏ tuyệt đối về backend hosted. Xem docs/app-map/ops/native-deploy.md.
NEXT_PUBLIC_API_BASE=

# Trên Vercel: thêm cùng tập biến trong Project → Settings → Environment Variables.
# Đánh dấu *_KEY là server-only (không "Expose to Browser").
