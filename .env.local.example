# Supabase — project: ForFish (znzgugvfhgmiszqgjulk)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://znzgugvfhgmiszqgjulk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY — KHÔNG để rò sang client. Dùng cho /api/auth/sso để tạo
# session sau khi SDWork xác thực credential. Lấy ở Dashboard → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SSO ForFish ↔ SDWork (xem docs/integration/sdwork-sso-contract.md).
# Khi 2 biến này trống → /api/auth/sso trả 503, login fallback về tài khoản
# nội bộ ForFish (đăng ký /dang-ky).
SDWORK_VERIFY_URL=https://api.sdwork.example.com/v1/auth/verify-fisherman
SDWORK_VERIFY_KEY=shared-secret-key-from-sdwork

# Copy file này thành .env.local. Trên Vercel: thêm cùng tập biến trong
# Project → Settings → Environment Variables (đánh dấu *_KEY là server-only).
